<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles/show.css">
</head>
<body>
    <h1>Attendance details</h1>
        <% if (locals.attendanceData) { %>
            <table>
                <thead>
                    <tr>
                        <th>Date</th>

                        <% 
                            const len = Object.keys(attendanceData).length - 1
                            const rollNumbers = Object.keys(Object.values(attendanceData)[len]);
                            rollNumbers.forEach(roll => { 
                        %>
                        <th><%= roll %></th>
                        <% }) %>
                    </tr>
                </thead>
                <tbody>
                    <% 
                        Object.entries(attendanceData).forEach(([date, attendance]) => { 
                    %>
                        <tr>
                            <td><%= date %></td>
                            <% rollNumbers.forEach(roll => { %>
                                <td><%= attendance[roll] || '-' %></td>
                            <% }) %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p>No attendance data available.</p>
        <% } %>
</body>
</html>
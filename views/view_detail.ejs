<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Volunteer Details</title>
    <link rel="stylesheet" href="/styles/view_detail.css">
</head>
<body>
    <div class="tables">
        <h2>Volunteer Details</h2>
        <table>
            <tr>
                <th>Roll Number</th>
                <td><%= volunteer[0].roll_no %></td>
            </tr>
            <tr>
                <th>Name</th>
                <td><%= volunteer[0].name %></td>
            </tr>
            <tr>
                <th>Role</th>
                <td><%= volunteer[0].role %></td>
            </tr>
            <tr>
                <th>Schedule</th>
                <td>
                    <% volunteer.forEach(v => { %>
                        <%= v.day %><br>
                    <% }) %>
                </td>
            </tr>
        </table>
    </div>
</body>
</html>
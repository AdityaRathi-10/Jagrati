<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles/donation.css">
</head>
<body>
    <div class="container">
        <div class="images">
            
        </div>
        <div class="main">
            <div class="msg">
                <h1>WELCOME TO <br><span><img src="/images/logo.jpg" alt="" style="width: 150px;"></span></h1>
                <p>"Education not only for privileged, but for all."</p>
                <br>
            </div>
            <div class="box">
                <form action="/user/donate" method="post">
                    <h1>Donate here</h1>
                    <div>
                        <label for="">Name</label>
                        <input type="text" name="username" required>
                    </div>
                    <div>
                        <label for="">Email</label>
                        <input type="email" name="email" required>
                    </div>
                    <div>
                        <label for="">Address</label>
                        <input type="text" name="address" required>
                    </div>
                    <div>
                        <label for="">Amount</label>
                        <input type="text" name="amount" required>
                    </div>
                    <div>
                        <label for="">Contact</label>
                        <input type="number" name="contact" required>
                    </div>
                    <div>
                        <label for="">Payment Id</label>
                        <input type="text" name="payment" required>
                    </div> 
                    <div>
                        <label for="">Your views on JAGRITI</label>
                        <input type="text">
                    </div>
                    <div>
                        <label for="">Enter transaction screenshot</label>
                        <input type="file">
                    </div>
                    
                    <div>
                        <button class="signup" type="submit">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>

</html>